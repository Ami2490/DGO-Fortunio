rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: config
    //   - web: object (navbar, hero, branding)
    // Collection: categories
    //   - name, image, span, order
    // Collection: pages
    //   - slug, title, content, images
    // Collection: benefits
    //   - iconName, title, description, order
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "admin@dgo.com" ||
         request.auth.token.email == "nardachonealanmartin@gmail.com");
    }

    // Rules
    match /config/siteConfig {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /benefits/{benefitId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if true;
      allow update: if isAdmin();
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || (resource != null && resource.data.referredBy == request.auth.uid) || isAdmin();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /point_transactions/{txId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Analytics de la tienda (colección 'analitica')
    match /analitica/{eventId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Compatibilidad con ruta vieja (por si existe data legacy)
    match /data/analytics/{eventId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Comodín para cualquier otra colección: el admin puede hacer lo que quiera
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
